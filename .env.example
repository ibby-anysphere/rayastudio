# Keep this key server-side. Never prefix it with NEXT_PUBLIC_.
GEMINI_API_KEY=replace_with_a_fresh_key
OPENAI_API_KEY=replace_with_a_fresh_key

# Optional model overrides.
GEMINI_FAST_IMAGE_MODEL=gemini-3.1-flash-lite-image
GEMINI_PRO_IMAGE_MODEL=gemini-3-pro-image
OPENAI_ASSET_MODEL=gpt-image-1.5
